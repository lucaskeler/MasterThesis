def _add_volume_balance_constraints(model):
    """Add volume balance constraints for cut and fill soils."""
    # 1. Volume balance for cut soils (including disposal)
    def cut_volume_rule(model, i, k):
        fill_destinations = [(j, l) for (i2, k2, j, l) in model.ALLOWED_MOVEMENTS if i2 == i and k2 == k]

        return sum(
            model.x[i, k, j, l, t]
            for (j, l) in fill_destinations
            for t in model.T
        ) + sum(
            model.x_disposal[i, k, 'disposal', t]
            for t in model.T
        ) + sum( # NEW: Add soil sent to storage
            model.x_to_storage[i, k, s, t]
            for s in model.STORAGE_SITES
            for t in model.T
        ) == model.VOLUME[i, k]

    model.cut_volume_constraint = pyo.Constraint(
        model.CUT_LAYERS, rule=cut_volume_rule,
        doc="Volume excavated from cut soil (including disposal) must equal its volume"
    )
    
    def fill_volume_rule(model, j_fill, l_fill): # Renamed j, l for clarity
        cut_sources = [(i, k) for (i, k, j2, l2) in model.ALLOWED_MOVEMENTS if j2 == j_fill and l2 == l_fill]

        # Soil from direct pit-to-pit
        direct_inflow = sum(
            model.x[i_cut, k_cut, j_fill, l_fill, t]
            for (i_cut, k_cut) in cut_sources
            for t in model.T
        )
        # Soil from borrow
        borrow_inflow = sum(
            model.x_borrow['borrow', j_fill, l_fill, t]
            for t in model.T
        )
        # NEW: Soil received from storage
        # Sum over all original cut layers (i_orig, k_orig) and storage sites (s_site)
        # that are allowed to supply this fill layer (j_fill, l_fill)
        storage_inflow = sum(
            model.x_from_storage[i_orig, k_orig, s_site, j_fill, l_fill, t]
            for (i_orig, k_orig, s_site, jf, lf) in model.ALLOWED_STORAGE_TO_FILL_PATHS
            if jf == j_fill and lf == l_fill # Ensure we are summing for the correct fill layer
            for t in model.T
        )
        return direct_inflow + borrow_inflow + storage_inflow == model.VOLUME[j_fill, l_fill]

    # Keep the constraint definition the same
    model.fill_volume_constraint = pyo.Constraint(
        model.FILL_LAYERS, rule=fill_volume_rule,
        doc="Volume filled into fill soil (including borrow and storage) must meet its volume"
    )

def _add_linking_constraints(model):
    """Add constraints to link flow variables with activity variables."""
    # 3. Link variables for movement
    def link_cut_rule(model, i, k, t):
        fill_destinations = [(j, l) for (i2, k2, j, l) in model.ALLOWED_MOVEMENTS if i2 == i and k2 == k]

        outflow = sum(
            model.x[i, k, j, l, t] for (j, l) in fill_destinations
        ) + sum(
            model.x_disposal[i, k, d, t] for d in model.DISPOSAL_PITS
        ) + sum( # NEW: Add flow to storage
            model.x_to_storage[i, k, s, t] for s in model.STORAGE_SITES
        )
        
        # Big M value - max volume that could flow
        big_m = model.VOLUME[i, k]
        
        # Flow can only happen if y_cut is 1
        return outflow <= big_m * model.y_cut[i, k, t]
    
    model.link_cut_constraint = pyo.Constraint(
        model.CUT_LAYERS, model.T,
        rule=link_cut_rule,
        doc="Flow from cut soil is only allowed if activity variable is 1"
    )
    
    def link_fill_rule(model, j_fill, l_fill, t): # Renamed j,l,t for clarity
        cut_sources = [(i, k) for (i, k, j2, l2) in model.ALLOWED_MOVEMENTS if j2 == j_fill and l2 == l_fill]

        direct_inflow_t = sum(
            model.x[i_cut, k_cut, j_fill, l_fill, t] for (i_cut, k_cut) in cut_sources
        )
        borrow_inflow_t = sum(
            model.x_borrow[b, j_fill, l_fill, t] for b in model.BORROW_PITS
        )
        # NEW: Add flow from storage for this specific period t
        storage_inflow_t = sum(
            model.x_from_storage[i_orig, k_orig, s_site, j_fill, l_fill, t]
            for (i_orig, k_orig, s_site, jf, lf) in model.ALLOWED_STORAGE_TO_FILL_PATHS
            if jf == j_fill and lf == l_fill
        )
        
        inflow = direct_inflow_t + borrow_inflow_t + storage_inflow_t
        big_m = model.VOLUME[j_fill, l_fill]
        return inflow <= big_m * model.y_fill[j_fill, l_fill, t]

    # Keep constraint definition
    model.link_fill_constraint = pyo.Constraint(
        model.FILL_LAYERS, model.T,
        rule=link_fill_rule,
        doc="Flow to fill soil is only allowed if activity variable is 1"
