def save_solution(model, layers_df, filename_prefix="soil_transport_solution"):
    """
    Extract and save optimization solution data for later inspection.
    """
    solution_data = {}
    summary_data_dict = {} # Use a temporary dict for summary

    # 1. Basic solution info
    summary_data_dict['objective_value'] = pyo.value(model.objective) if hasattr(model, 'objective') else None
    summary_data_dict['total_cost'] = pyo.value(model.total_cost) if hasattr(model, 'total_cost') else None
    summary_data_dict['makespan'] = pyo.value(model.makespan) if hasattr(model, 'makespan') else None
    summary_data_dict['total_time_periods'] =  len(model.T) if hasattr(model, 'T') and model.T is not None else 0
    summary_data_dict['cut_pits_list'] = list(model.CUT_PITS) if hasattr(model, 'CUT_PITS') else []
    summary_data_dict['fill_pits_list'] = list(model.FILL_PITS) if hasattr(model, 'FILL_PITS') else []
    summary_data_dict['disposal_pits_list'] = list(model.DISPOSAL_PITS) if hasattr(model, 'DISPOSAL_PITS') else []
    summary_data_dict['borrow_pits_list'] = list(model.BORROW_PITS) if hasattr(model, 'BORROW_PITS') else []
    summary_data_dict['storage_sites_list'] = list(model.STORAGE_SITES) if hasattr(model, 'STORAGE_SITES') else []
    
    month_labels_orig = model.month_labels if hasattr(model, 'month_labels') else {}
    if month_labels_orig and any(month_labels_orig) and isinstance(list(month_labels_orig.keys())[0], int): 
        summary_data_dict['month_labels'] = {str(k): v for k, v in month_labels_orig.items()}
    else:
        summary_data_dict['month_labels'] = month_labels_orig if month_labels_orig else {}

    summary_data_dict['pit_to_object'] = model.pit_to_object if hasattr(model, 'pit_to_object') else {}
    summary_data_dict['all_objects'] = list(model.OBJECTS) if hasattr(model, 'OBJECTS') else []
    summary_data_dict['MONTHLY_CAPACITY'] = pyo.value(model.MONTHLY_CAPACITY) if hasattr(model, 'MONTHLY_CAPACITY') else 0
    summary_data_dict['DISPOSAL_COST'] = pyo.value(model.DISPOSAL_COST) if hasattr(model, 'DISPOSAL_COST') else 0
    summary_data_dict['BORROW_COST'] = pyo.value(model.BORROW_COST) if hasattr(model, 'BORROW_COST') else 0
    summary_data_dict['COST_TO_STORAGE'] = pyo.value(model.COST_TO_STORAGE) if hasattr(model, 'COST_TO_STORAGE') else 0
    summary_data_dict['COST_FROM_STORAGE'] = pyo.value(model.COST_FROM_STORAGE) if hasattr(model, 'COST_FROM_STORAGE') else 0
    summary_data_dict['STORABLE_SOILS'] = list(model.STORABLE_SOILS) if hasattr(model, 'STORABLE_SOILS') else []
    
    solution_data['summary'] = summary_data_dict
    
    # 2. Extract flows (model.x)
    flow_data = []
    if hasattr(model, 'ALLOWED_MOVEMENTS') and hasattr(model, 'x') and hasattr(model, 'T') and model.T is not None:
        for (i, k, j, l) in model.ALLOWED_MOVEMENTS: # Iterate over the static components of a movement path
            # Determine the priority for this (i,k,j,l) path. This priority is time-independent.
            priority_val = 1 # Default priority
            priority_key_for_param = (i, k, j, l) # Key for MOVEMENT_PRIORITY is (i,k,j,l)
            
            if hasattr(model, 'MOVEMENT_PRIORITY') and priority_key_for_param in model.MOVEMENT_PRIORITY:
                 priority_val = pyo.value(model.MOVEMENT_PRIORITY[priority_key_for_param])
            
            # Now, iterate over time periods to get actual flow values for this path
            for t_period in model.T:
                key_x = (i, k, j, l, t_period) # Key for the flow variable model.x, which IS time-dependent
                
                # Ensure key_x is valid for model.x before trying to access it
                if key_x not in model.x:
                    continue
                
                flow_value = pyo.value(model.x[key_x])
                if flow_value is not None and flow_value > 0.1:
                    flow_data.append({
                        'time_period': t_period,
                        'month': summary_data_dict['month_labels'].get(str(t_period), f"Month {t_period}"),
                        'source_pit': i,
                        'source_object': summary_data_dict['pit_to_object'].get(i, "Unknown"),
                        'source_soil': k,
                        'destination_pit': j,
                        'destination_object': summary_data_dict['pit_to_object'].get(j, "Unknown"),
                        'destination_soil': l,
                        'volume': flow_value,
                        'priority': priority_val if priority_val is not None else 1 # Use the pre-fetched priority
                    })
    solution_data['flows'] = flow_data
    
    # 3. Extract disposal
    disposal_data = []
    if hasattr(model, 'CUT_LAYERS') and hasattr(model, 'x_disposal') and hasattr(model, 'T') and model.T is not None and hasattr(model, 'DISPOSAL_PITS'):
        disposal_pit_id = 'disposal' if 'disposal' in model.DISPOSAL_PITS else (list(model.DISPOSAL_PITS)[0] if model.DISPOSAL_PITS else None)
        if disposal_pit_id:
            for (i, k) in model.CUT_LAYERS:
                for t_period in model.T:
                    key = (i, k, disposal_pit_id, t_period)
                    if key not in model.x_disposal: 
                        continue
                    flow_value = pyo.value(model.x_disposal[key])
                    if flow_value is not None and flow_value > 0.1:
                        disposal_data.append({
                            'time_period': t_period,
                            'month': summary_data_dict['month_labels'].get(str(t_period), f"Month {t_period}"),
                            'source_pit': i,
                            'source_object': summary_data_dict['pit_to_object'].get(i, "Unknown"),
                            'soil_type': k,
                            'volume': flow_value
                        })
    solution_data['disposal'] = disposal_data
    
    # 4. Extract borrow
    borrow_data = []
    if hasattr(model, 'FILL_LAYERS') and hasattr(model, 'x_borrow') and hasattr(model, 'T') and model.T is not None and hasattr(model, 'BORROW_PITS'):
        borrow_pit_id = 'borrow' if 'borrow' in model.BORROW_PITS else (list(model.BORROW_PITS)[0] if model.BORROW_PITS else None)
        if borrow_pit_id:
            for (j, l) in model.FILL_LAYERS:
                for t_period in model.T:
                    key = (borrow_pit_id, j, l, t_period)
                    if key not in model.x_borrow: 
                        continue
                    flow_value = pyo.value(model.x_borrow[key])
                    if flow_value is not None and flow_value > 0.1:
                        borrow_data.append({
                            'time_period': t_period,
                            'month': summary_data_dict['month_labels'].get(str(t_period), f"Month {t_period}"),
                            'destination_pit': j,
                            'destination_object': summary_data_dict['pit_to_object'].get(j, "Unknown"),
                            'soil_type': l,
                            'volume': flow_value
                        })
    solution_data['borrow'] = borrow_data

    # 5. Extract flows to storage (x_to_storage)
    to_storage_data = []
    if hasattr(model, 'CUT_LAYERS') and hasattr(model, 'STORAGE_SITES') and hasattr(model, 'x_to_storage') and hasattr(model, 'T') and model.T is not None:
        for (i, k) in model.CUT_LAYERS:
            for s in model.STORAGE_SITES:
                for t_period in model.T:
                    key = (i, k, s, t_period)
                    if key not in model.x_to_storage:
                        continue
                    flow_value = pyo.value(model.x_to_storage[key])
                    if flow_value is not None and flow_value > 0.1:
                        to_storage_data.append({
                            'time_period': t_period,
                            'month': summary_data_dict['month_labels'].get(str(t_period), f"Month {t_period}"),
                            'source_pit': i,
                            'source_object': summary_data_dict['pit_to_object'].get(i, "Unknown"),
                            'soil_type': k, 
                            'storage_site': s,
                            'volume': flow_value
                        })
    solution_data['to_storage_flows'] = to_storage_data

    # 6. Extract flows from storage (x_from_storage)
    from_storage_data = []
    if hasattr(model, 'x_from_storage') and hasattr(model, 'T') and model.T is not None:
        # model.x_from_storage is indexed by (i_orig, k_orig, s_site, j_fill, l_fill, t_period)
        for (i_orig, k_orig, s_site, j_fill, l_fill, t_period) in model.x_from_storage: 
            flow_value = pyo.value(model.x_from_storage[i_orig, k_orig, s_site, j_fill, l_fill, t_period])
            if flow_value is not None and flow_value > 0.1:
                priority_val = 1 # Default priority
                
                priority_key_param = (i_orig, k_orig, j_fill, l_fill) 
                
                if hasattr(model, 'MOVEMENT_PRIORITY') and priority_key_param in model.MOVEMENT_PRIORITY:
                    priority_val = pyo.value(model.MOVEMENT_PRIORITY[priority_key_param])
                
                from_storage_data.append({
                    'time_period': t_period,
                    'month': summary_data_dict['month_labels'].get(str(t_period), f"Month {t_period}"),
                    'source_pit_original': i_orig,
                    'source_soil_original': k_orig, 
                    'source_object_original': summary_data_dict['pit_to_object'].get(i_orig, "Unknown_Orig"), 
                    'storage_site': s_site, 
                    'destination_pit': j_fill,
                    'destination_object': summary_data_dict['pit_to_object'].get(j_fill, "Unknown_Dest"),
                    'destination_soil_required': l_fill, 
                    'volume': flow_value,
                    'priority': priority_val if priority_val is not None else 1
                })
    solution_data['from_storage_flows'] = from_storage_data

    # 7. Extract storage inventory (inventory_storage)
    storage_inventory_data = []
    if hasattr(model, 'inventory_storage') and hasattr(model, 'T') and model.T is not None and len(model.T) > 0:
        time_first = model.T.first() 
        time_last = model.T.last()

        for (i_orig, k_orig, s_site, t_period) in model.inventory_storage: 
            inventory_level = pyo.value(model.inventory_storage[i_orig, k_orig, s_site, t_period])
            if inventory_level is not None and (inventory_level > 0.1 or t_period == time_first or t_period == time_last):
                storage_inventory_data.append({
                    'time_period': t_period,
                    'month': summary_data_dict['month_labels'].get(str(t_period), f"Month {t_period}"),
                    'original_cut_pit': i_orig,
                    'original_soil_type': k_orig,
                    'storage_site': s_site,
                    'inventory_volume': inventory_level
                })
    solution_data['storage_inventory'] = storage_inventory_data
    
    # 8. Extract activity periods
    activity_periods_data = {}
    if hasattr(model, 'OBJECTS') and hasattr(model, 'has_any_activity') and \
       hasattr(model, 'start_period') and hasattr(model, 'end_period') and \
       hasattr(model, 'has_activity') and hasattr(model, 'T') and model.T is not None:
        for obj_iter in model.OBJECTS:
            has_any = None
            if obj_iter in model.has_any_activity: 
                 has_any = pyo.value(model.has_any_activity[obj_iter])
            
            if has_any is not None and has_any > 0.5: 
                start_val = pyo.value(model.start_period[obj_iter]) if obj_iter in model.start_period else None
                end_val = pyo.value(model.end_period[obj_iter]) if obj_iter in model.end_period else None
                
                active_p = []
                for t_period in model.T:
                    key = (obj_iter, t_period)
                    has_activity_val = pyo.value(model.has_activity[key]) if key in model.has_activity else None
                    if has_activity_val is not None and has_activity_val > 0.5:
                        active_p.append(t_period)
                            
                activity_periods_data[obj_iter] = {
                    'start_period': int(start_val) if start_val is not None else None,
                    'end_period': int(end_val) if end_val is not None else None,
                    'active_periods': active_p,
                    'start_month': summary_data_dict['month_labels'].get(str(int(start_val)), f"Month {int(start_val)}") if start_val is not None else None,
                    'end_month': summary_data_dict['month_labels'].get(str(int(end_val)), f"Month {int(end_val)}") if end_val is not None else None
                }
    solution_data['activity_periods'] = activity_periods_data
    
    # Save to JSON
    json_filename = f"{filename_prefix}.json"
    with open(json_filename, 'w') as f:
        json.dump(solution_data, f, indent=2)
    print(f"Solution data saved to {json_filename}")

    # Save relevant parts to CSV
    if flow_data:
        pd.DataFrame(flow_data).to_csv(f"{filename_prefix}_flows.csv", index=False)
        print(f"Flow data saved to {filename_prefix}_flows.csv")
    if disposal_data:
        pd.DataFrame(disposal_data).to_csv(f"{filename_prefix}_disposal.csv", index=False)
        print(f"Disposal data saved to {filename_prefix}_disposal.csv")
    if borrow_data:
        pd.DataFrame(borrow_data).to_csv(f"{filename_prefix}_borrow.csv", index=False)
        print(f"Borrow data saved to {filename_prefix}_borrow.csv")
    if to_storage_data:
        pd.DataFrame(to_storage_data).to_csv(f"{filename_prefix}_to_storage.csv", index=False)
        print(f"To_storage flow data saved to {filename_prefix}_to_storage.csv")
    if from_storage_data: 
        pd.DataFrame(from_storage_data).to_csv(f"{filename_prefix}_from_storage.csv", index=False)
        print(f"From_storage flow data saved to {filename_prefix}_from_storage.csv")
    if storage_inventory_data:
        pd.DataFrame(storage_inventory_data).to_csv(f"{filename_prefix}_storage_inventory.csv", index=False)
        print(f"Storage inventory data saved to {filename_prefix}_storage_inventory.csv")
    
    return solution_data

# %%
def main():
    """Main function to run the soil transportation optimization."""
    print("Starting Soil Transportation Optimization with Monthly Time Windows and Environmental Compatibility")

    SOLUTION_FILENAME_PREFIX = "soil_transport_solution"

    # Set this flag to True to solve the model, False to load and visualize existing solution

    SOLVE_AND_SAVE_MODEL = False 

    solution_data = None
    
    # Always load and process initial data for context (pit_coords, base_cut_pits, etc.)
    try:
        data_objects = load_data()
        print("Successfully loaded data from pickle file")
    except Exception as e:
        print(f"Error loading data: {e}")
        return

    layers_df, costs_df, pit_coords, soil_compatibility, cut_pits, fill_pits, df_planning = process_data(data_objects)
    
    print(f"layers_df shape: {layers_df.shape}")
    print(f"costs_df shape: {costs_df.shape}")
    print(f"Number of cut_pits: {len(cut_pits)}")
    print(f"Number of fill_pits: {len(fill_pits)}")
    
    if SOLVE_AND_SAVE_MODEL:
        print("\nData Summary (before solving):")
        print(f"Number of soil types: {len(set(layers_df['soil_type']))}")
        print(f"Number of cost entries: {len(costs_df)}")
        
        total_supply = layers_df[layers_df['pit_type'] == 'cut']['volume'].sum()
        total_demand = abs(layers_df[layers_df['pit_type'] == 'fill']['volume'].sum())
        print(f"Total supply: {total_supply:.2f} m³")
        print(f"Total demand: {total_demand:.2f} m³")
        print(f"Net balance: {total_supply - total_demand:.2f} m³ {'(excess supply)' if total_supply > total_demand else '(supply shortage)'}\n")
        
        time_periods = 72       
        time_limit = 1000 # Increased time limit for Gurobi's MIPGap tolerance
        
        model = create_and_solve_model(
            layers_df, costs_df, soil_compatibility, cut_pits, fill_pits, pit_coords,
            time_periods=time_periods, time_limit=time_limit, df_planning=df_planning
        )
        
        if model:
            print("\nSaving solution...")
            solution_data = save_solution(model, layers_df, filename_prefix=SOLUTION_FILENAME_PREFIX)
        else:
            print("Model solving failed. Cannot visualize or save.")
            return
    else:
        print(f"\nLoading solution from {SOLUTION_FILENAME_PREFIX}.json..")
        try:
            with open(f"{SOLUTION_FILENAME_PREFIX}.json", 'r') as f:
                solution_data = json.load(f)
            print(f"Successfully loaded solution from {SOLUTION_FILENAME_PREFIX}.json")
        except FileNotFoundError:
            print(f"Solution file {SOLUTION_FILENAME_PREFIX}.json not found. Run with SOLVE_AND_SAVE_MODEL=True first.")
            return
        except Exception as e:
            print(f"Error loading solution data: {e}")
            return

    if solution_data and 'summary' in solution_data:
        print("\nVisualizing solution...")
        # Pass df_planning to visualize_solution_from_data if create_activity_heatmap_from_data needs it
        # for original month labels from planning data (though it's better if month_labels are fully in solution_data)
        visualize_solution_from_data(solution_data, layers_df, pit_coords, cut_pits, fill_pits, df_planning)
    else:
        print("No solution data available for visualization.")

# %%
main()
