def create_activity_heatmap(model, layers_df):
    """Create a heatmap of object activity over time."""
    # Create a new figure just for the activity heatmap
    plt.figure(figsize=(16, 10))

    # Get unique objects in sorted order
    objects = sorted(list(set([obj for obj in model.pit_to_object.values() if obj != None])))
    if len(objects) > 25:  # Limit to 25 objects for readability
        objects = objects[:25]

    # Initialize the activity matrix with zeros (0 = no activity)
    activity_matrix = np.zeros((len(objects), len(model.T)))
    periods = sorted(model.T)

    # Print debug information
    print(f"Creating heatmap for {len(objects)} objects across {len(periods)} time periods")

    # Directly extract activity data from optimization results
    try:
        # Create dictionaries to track total volumes by object, period, and activity type
        volumes = {obj: {t: {'cut': 0.0, 'fill': 0.0} for t in periods} for obj in objects}
        
        # Extract normal transportation volumes
        print("Extracting transportation data...")
        for t in periods:
            for (i, k, j, l) in model.ALLOWED_MOVEMENTS:
                flow = pyo.value(model.x[i, k, j, l, t])
                if flow > 0.1:  # Only count significant flows
                    src_obj = model.pit_to_object.get(i)
                    dst_obj = model.pit_to_object.get(j)
                    
                    if src_obj in objects:
                        volumes[src_obj][t]['cut'] += flow
                    
                    if dst_obj in objects:
                        volumes[dst_obj][t]['fill'] += flow
        
        # Extract disposal volumes
        print("Extracting disposal data...")
        for t in periods:
            for (i, k) in model.CUT_LAYERS:
                flow = pyo.value(model.x_disposal[i, k, 'disposal', t])
                if flow > 0.1:
                    src_obj = model.pit_to_object.get(i)
                    if src_obj in objects:
                        volumes[src_obj][t]['cut'] += flow
        
        # Extract borrow volumes
        print("Extracting borrow data...")
        for t in periods:
            for (j, l) in model.FILL_LAYERS:
                flow = pyo.value(model.x_borrow['borrow', j, l, t])
                if flow > 0.1:
                    dst_obj = model.pit_to_object.get(j)
                    if dst_obj in objects:
                        volumes[dst_obj][t]['fill'] += flow

        # NEW: Extract to_storage volumes
        print("Extracting to_storage data for heatmap...")
        for t in periods:
            for (i, k) in model.CUT_LAYERS:
                for s_site in model.STORAGE_SITES:
                    flow = pyo.value(model.x_to_storage[i, k, s_site, t])
                    if flow > 0.1:
                        src_obj = model.pit_to_object.get(i)
                        if src_obj in objects: # Ensure object is in the list being heatmapped
                            volumes[src_obj][t]['cut'] += flow # Movement to storage is a "cut" type activity for the source object
        
        # NEW: Extract from_storage volumes
        print("Extracting from_storage data for heatmap...")
        for t in periods:
            for (j, l) in model.FILL_LAYERS:
                for s_site in model.STORAGE_SITES:
                    flow = pyo.value(model.x_from_storage[s_site, j, l, t])
                    if flow > 0.1:
                        dst_obj = model.pit_to_object.get(j)
                        if dst_obj in objects: # Ensure object is in the list being heatmapped
                            volumes[dst_obj][t]['fill'] += flow # Movement from storage is a "fill" type activity for the destination object

        # Now populate the activity matrix based on extracted volumes
        for obj_idx, obj in enumerate(objects):
            for period_idx, t in enumerate(periods):
                cut_volume = volumes[obj][t]['cut']
                fill_volume = volumes[obj][t]['fill']
                
                # Assign activity value: 0=none, 1=cut, 2=fill, 3=both
                if cut_volume > 0 and fill_volume > 0:
                    activity_matrix[obj_idx, period_idx] = 3  # Both activities
                elif cut_volume > 0:
                    activity_matrix[obj_idx, period_idx] = 1  # Cut only
                elif fill_volume > 0:
                    activity_matrix[obj_idx, period_idx] = 2  # Fill only
        
        # Sample debug output to verify data is being captured
        print("\nSample activity data for first 3 objects:")
        for obj in objects[:3]:
            active_periods = [t for t in periods if volumes[obj][t]['cut'] > 0 or volumes[obj][t]['fill'] > 0]
            if active_periods:
                print(f"  Object {obj}: Active in {len(active_periods)} periods")
                sample_period = active_periods[0]
                print(f"    Period {sample_period}: Cut={volumes[obj][sample_period]['cut']:.1f}, Fill={volumes[obj][sample_period]['fill']:.1f}")
            else:
                print(f"  Object {obj}: No activity detected")

        # Create a custom colormap: purple for no activity, blue for cut, yellow for fill, green for both
        cmap = plt.cm.colors.ListedColormap(['#2D0A31', '#1E88E5', '#FFC107', '#4CAF50'])
        bounds = [0, 0.5, 1.5, 2.5, 3.5]
        norm = plt.cm.colors.BoundaryNorm(bounds, cmap.N)
        
        # Plot the activity heatmap
        img = plt.imshow(activity_matrix, cmap=cmap, norm=norm, aspect='auto', interpolation='nearest')
        
        # Create a custom colorbar with clear labels
        cbar = plt.colorbar(img, ticks=[0.25, 1, 2, 3])
        cbar.set_ticklabels(['No Activity', 'Cut Only', 'Fill Only', 'Both'])
        cbar.set_label('Activity Type')
        
        # Set labels and title
        plt.yticks(np.arange(len(objects)), objects)
        
        # Only show every nth label to avoid crowding
        step = max(1, len(periods) // 15)  # Show at most 15 labels
        plt.xticks(np.arange(0, len(periods), step), 
                [model.month_labels.get(periods[i], f"Month {periods[i]}") for i in range(0, len(periods), step)], 
                rotation=45)
        
        plt.xlabel('Month')
        plt.ylabel('Object')
        plt.title('Monthly Activity Schedule by Object')
        plt.tight_layout()
        
        # Save the heatmap to a separate file
        plt.savefig("object_activity_heatmap.png", dpi=300)
        print("Activity heatmap saved as 'object_activity_heatmap.png'")
        
    except Exception as e:
        print(f"Error generating activity heatmap: {e}")

