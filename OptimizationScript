        for i, flow_item in enumerate(sorted_movements):
            print(f"  {i+1}. {flow_item.get('source_pit')} ({flow_item.get('source_object')}, {flow_item.get('source_soil')}) → "
                  f"{flow_item.get('destination_pit')} ({flow_item.get('destination_object')}, {flow_item.get('destination_soil')}): "
                  f"{flow_item.get('volume',0):.2f} m³ (Priority: {flow_item.get('priority', 'N/A')})")
        
        print("\nActivity by Object:")
        object_activity = {}
        all_objects_list = summary.get('all_objects', []) 

        for obj_id_loop in all_objects_list:
            if obj_id_loop is not None and obj_id_loop != 'nan': 
                 object_activity[obj_id_loop] = {'cut': 0.0, 'fill': 0.0, 'disposal': 0.0, 'borrow': 0.0, 'to_storage': 0.0, 'from_storage': 0.0}

        # This aggregation re-calculates totals for objects based on the detailed flow lists
        # Flows (direct pit-to-pit)
        for flow_item in flows:
            src_obj = flow_item.get('source_object')
            dst_obj = flow_item.get('destination_object')
            volume = flow_item.get('volume', 0)
            if volume > 0.1:
                if src_obj in object_activity: object_activity[src_obj]['cut'] += volume
                if dst_obj in object_activity: object_activity[dst_obj]['fill'] += volume

        # Disposal
        for flow_item in disposal:
            src_obj = flow_item.get('source_object')
            volume = flow_item.get('volume', 0)
            if volume > 0.1:
                if src_obj in object_activity:
                    object_activity[src_obj]['disposal'] += volume
                    object_activity[src_obj]['cut'] += volume # Disposal is a form of "cut"

        # Borrow
        for flow_item in borrow:
            dst_obj = flow_item.get('destination_object')
            volume = flow_item.get('volume', 0)
            if volume > 0.1:
                if dst_obj in object_activity:
                    object_activity[dst_obj]['borrow'] += volume
                    object_activity[dst_obj]['fill'] += volume # Borrow is a form of "fill"
                    
        # To Storage
        for flow_item in to_storage_flows:
            src_obj = flow_item.get('source_object') # Soil comes from this object's cut pit
            volume = flow_item.get('volume', 0)
            if volume > 0.1:
                if src_obj in object_activity:
                    object_activity[src_obj]['to_storage'] += volume
                    object_activity[src_obj]['cut'] += volume # Movement to storage is a "cut" for the source object
        
        # From Storage (NEW STRUCTURE)
        for flow_item in from_storage_flows_detailed: # Use the detailed list
            # The key is 'destination_object' as it indicates which object is receiving the fill
            dst_obj = flow_item.get('destination_object') 
            volume = flow_item.get('volume', 0)
            if volume > 0.1:
                if dst_obj in object_activity:
                    object_activity[dst_obj]['from_storage'] += volume
                    object_activity[dst_obj]['fill'] += volume # Movement from storage is a "fill" for the destination object

        sorted_objects = sorted([item for item in object_activity.items() if item[1]['cut'] + item[1]['fill'] > 0.1],
                            key=lambda x: x[1]['cut'] + x[1]['fill'],
                            reverse=True)

        for obj, data in sorted_objects:
            print(f"  Object {obj}: {data['cut']:.2f} m³ total sourced, {data['fill']:.2f} m³ total placed, "
                  f"{data['disposal']:.2f} m³ disposal, {data['borrow']:.2f} m³ borrow, "
                  f"{data['to_storage']:.2f} m³ to storage, {data['from_storage']:.2f} m³ from storage")

    except Exception as e:
        print(f"Error calculating statistics: {e}")
        import traceback
        traceback.print_exc()

