def _collect_edges_from_data(solution_data):
    """Collect edges for the graph based on the loaded solution data."""
    edges = []
    
    # Aggregate normal transportation flows
    agg_flows = {}
    for flow in solution_data['flows']:
        key = (flow['source_pit'], flow['destination_pit'], flow['source_soil'], flow['destination_soil'], 'normal')
        if key not in agg_flows:
            agg_flows[key] = {'weight': 0, 'time_periods': []}
        agg_flows[key]['weight'] += flow['volume']
        if flow['time_period'] not in agg_flows[key]['time_periods']: # Avoid duplicate time periods if flow is split
             agg_flows[key]['time_periods'].append(flow['time_period'])
    
    for (i, j, k, l, type_val), data in agg_flows.items():
        if data['weight'] > 0.1:
            edges.append((i, j, {
                'weight': data['weight'],
                'time_periods': sorted(list(set(data['time_periods']))), # Ensure unique and sorted
                'cut_soil': k,
                'fill_soil': l,
                'type': type_val
            }))

    # Aggregate disposal flows
    agg_disposal = {}
    for flow in solution_data['disposal']:
        key = (flow['source_pit'], 'disposal', flow['soil_type'], 'disposal') # d_pit is 'disposal'
        if key not in agg_disposal:
            agg_disposal[key] = {'weight': 0, 'time_periods': []}
        agg_disposal[key]['weight'] += flow['volume']
        if flow['time_period'] not in agg_disposal[key]['time_periods']:
             agg_disposal[key]['time_periods'].append(flow['time_period'])

    for (i, d, k, type_val), data in agg_disposal.items():
        if data['weight'] > 0.1:
            edges.append((i, d, {
                'weight': data['weight'],
                'time_periods': sorted(list(set(data['time_periods']))),
                'cut_soil': k,
                'fill_soil': None,
                'type': type_val
            }))

    # Aggregate borrow flows
    agg_borrow = {}
    for flow in solution_data['borrow']:
        key = ('borrow', flow['destination_pit'], flow['soil_type'], 'borrow') # b_pit is 'borrow'
        if key not in agg_borrow:
            agg_borrow[key] = {'weight': 0, 'time_periods': []}
        agg_borrow[key]['weight'] += flow['volume']
        if flow['time_period'] not in agg_borrow[key]['time_periods']:
             agg_borrow[key]['time_periods'].append(flow['time_period'])

    for (b, j, l, type_val), data in agg_borrow.items():
        if data['weight'] > 0.1:
            edges.append((b, j, {
                'weight': data['weight'],
                'time_periods': sorted(list(set(data['time_periods']))),
                'cut_soil': None,
                'fill_soil': l,
                'type': type_val
            }))
            
    # Aggregate to_storage flows
    agg_to_storage = {}
    for flow in solution_data['to_storage_flows']:
        key = (flow['source_pit'], flow['storage_site'], flow['soil_type'], 'to_storage')
        if key not in agg_to_storage:
            agg_to_storage[key] = {'weight': 0, 'time_periods': []}
        agg_to_storage[key]['weight'] += flow['volume']
        if flow['time_period'] not in agg_to_storage[key]['time_periods']:
             agg_to_storage[key]['time_periods'].append(flow['time_period'])

    for (i, s_site, k, type_val), data in agg_to_storage.items():
        if data['weight'] > 0.1:
            edges.append((i, s_site, {
                'weight': data['weight'],
                'time_periods': sorted(list(set(data['time_periods']))),
                'cut_soil': k,
                'fill_soil': None,
                'type': type_val
            }))

    agg_from_storage = {}
    for flow in solution_data['from_storage_flows']:
        # The 'destination_soil_required' is the 'l' (applicability) needed at the fill pit.
        # 'source_soil_original' (k_orig) should be equal to 'destination_soil_required' (l_fill)
        # for this flow to be valid as per our new model logic.
        # We use 'destination_soil_required' for the key as it represents the soil type being delivered.
        key = (flow['storage_site'], flow['destination_pit'], flow['destination_soil_required'], 'from_storage')
        if key not in agg_from_storage:
            agg_from_storage[key] = {'weight': 0, 'time_periods': []}
        agg_from_storage[key]['weight'] += flow['volume']
        if flow['time_period'] not in agg_from_storage[key]['time_periods']:
             agg_from_storage[key]['time_periods'].append(flow['time_period'])
             
    for (s_site, j, l_fill, type_val), data in agg_from_storage.items(): # l_fill is destination_soil_required
        if data['weight'] > 0.1:
            edges.append((s_site, j, {
                'weight': data['weight'],
                'time_periods': sorted(list(set(data['time_periods']))),
                'cut_soil': None,  # Immediate source is storage, not a specific original cut pit for this edge
                'fill_soil': l_fill, # The soil type (applicability) being delivered to the fill pit
                'type': type_val
            }))
            
    return edges

def _collect_time_data_from_data(solution_data):
            """Collect data on flow volumes by time period from saved solution data."""
            total_time_periods = solution_data['summary']['total_time_periods']
            time_data = {t: {'cut': 0, 'fill': 0, 'disposal': 0, 'borrow': 0,
                            'to_storage': 0, 'from_storage': 0} for t in range(1, total_time_periods + 1)}

            # Regular transportation
            for flow_item in solution_data['flows']:
                t = flow_item['time_period']
                volume = flow_item['volume']
                if volume > 0.1:
                    time_data[t]['cut'] += volume
                    time_data[t]['fill'] += volume
            
            # Disposal
            for flow_item in solution_data['disposal']:
                t = flow_item['time_period']
                volume = flow_item['volume']
                if volume > 0.1:
                    time_data[t]['disposal'] += volume
                    time_data[t]['cut'] += volume 
            
            # Borrow
            for flow_item in solution_data['borrow']:
                t = flow_item['time_period']
                volume = flow_item['volume']
                if volume > 0.1:
                    time_data[t]['borrow'] += volume
                    time_data[t]['fill'] += volume

            # Flows to storage
            for flow_item in solution_data['to_storage_flows']:
                t = flow_item['time_period']
                volume = flow_item['volume']
                if volume > 0.1:
                    time_data[t]['to_storage'] += volume
                    time_data[t]['cut'] += volume
                    
            # Flows from storage (NEW STRUCTURE)
            for flow_item in solution_data.get('from_storage_flows', []):
                t = flow_item.get('time_period')
                volume = flow_item.get('volume', 0)
                if t and volume > 0.1:
                    if t in time_data:
                        time_data[t]['from_storage'] += volume
                        # Soil from storage is used for a fill activity
                        time_data[t]['fill'] += volume
                    
            return time_data

def create_timeline_visualization_from_data(solution_data):
    """Create timeline visualization of soil movement volumes from saved data."""
    summary = solution_data.get('summary', {})
    month_labels_str_keys = summary.get('month_labels', {}) # Keys are already strings from save_solution
    
    # Infer total_time_periods more robustly
    all_periods_from_flows = set()
    for flow_list_key in ['flows', 'disposal', 'borrow', 'to_storage_flows', 'from_storage_flows', 'storage_inventory']:
        for item in solution_data.get(flow_list_key, []):
            if 'time_period' in item:
                all_periods_from_flows.add(item['time_period'])
    total_time_periods = max(all_periods_from_flows) if all_periods_from_flows else summary.get('total_time_periods', 45)


    monthly_capacity = summary.get('MONTHLY_CAPACITY', 0)
    # STORABLE_SOILS is no longer directly needed here as we sum up all disaggregated inventory

    plt.figure(figsize=(16, 12))
    
    time_data = _collect_time_data_from_data(solution_data) 

    periods = sorted(list(time_data.keys())) # Use keys from time_data
    if not periods: # Handle case with no flow data
        print("No flow data available for timeline visualization.")
        plt.close()
        return

    x_pos = np.arange(len(periods))
    # Ensure step is at least 1 and doesn't exceed number of periods for xticks
    step = max(1, len(periods) // 20) if len(periods) > 0 else 1
    
    plt.subplot(4, 1, 1)
    cut_volumes = [time_data[t]['cut'] for t in periods] 
    fill_volumes = [time_data[t]['fill'] for t in periods] 
    plt.bar(x_pos, cut_volumes, width=0.4, label='Total Excavated/Sourced', color='lightblue', align='edge')
    plt.bar(x_pos + 0.4, fill_volumes, width=0.4, label='Total Filled/Placed', color='lightgreen', align='edge') # Adjusted x_pos slightly for non-overlapping bars
    
    plt.xlabel('Month')
    plt.ylabel('Volume (m³)')
